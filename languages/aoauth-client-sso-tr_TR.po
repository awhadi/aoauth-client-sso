msgid "Type and press Enter to add scopes"
msgstr "Kapsam eklemek için yazın ve Enter’a basın"

#: admin/views/wizard.php:130
msgid ""
"Press Enter after each scope to add it. Common scopes: openid, email, profile"
msgstr ""
"Her kapsamdan sonra eklemek için Enter’a basın. Yaygın kapsamlar: openid, "
"email, profile"

#: admin/views/wizard.php:134
msgid "Provider Base URL / Discovery URL"
msgstr "Sağlayıcı temel URL / Discovery URL"

#: admin/views/wizard.php:141
msgid ""
"Enter the base URL of your OAuth server. Click Auto Discover to "
"automatically fetch the endpoints."
msgstr ""
"OAuth sunucunuzun temel URL’sini girin. Uç noktaları otomatik almak için "
"Otomatik keşfet’e tıklayın."

#: admin/views/wizard.php:145
msgid "Authorization Endpoint"
msgstr "Yetkilendirme uç noktası"

#: admin/views/wizard.php:147
msgid "The URL where users are redirected to authorize your application."
msgstr "Kullanıcıların uygulamanızı yetkilendirmek için yönlendirildiği URL."

#: admin/views/wizard.php:151
msgid "Token Endpoint"
msgstr "Token uç noktası"

#: admin/views/wizard.php:153
msgid "The URL where authorization codes are exchanged for access tokens."
msgstr "Yetkilendirme kodlarının erişim tokenlarıyla değiştirildiği URL."

#: admin/views/wizard.php:157
msgid "UserInfo Endpoint (Optional)"
msgstr "UserInfo uç noktası (isteğe bağlı)"

#: admin/views/wizard.php:159
msgid ""
"The URL where user profile information can be retrieved. May be optional if "
"using ID tokens."
msgstr ""
"Kullanıcı profil bilgilerinin alınabileceği URL. ID token kullanılıyorsa "
"isteğe bağlı olabilir."

