msgstr "İstemci kimlik bilgilerini başlıkta gönder (HTTP Basic Auth)"

#: admin/views/wizard.php:244
msgid "Send Client Credentials in Body (POST parameters)"
msgstr "İstemci kimlik bilgilerini gövdede gönder (POST parametreleri)"

#: admin/views/wizard.php:247
msgid ""
"Header method (HTTP Basic Auth using Authorization header) is more secure "
