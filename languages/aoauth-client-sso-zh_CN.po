msgid "Clear All Bot Verification Tokens"
msgstr "清除所有机器人验证令牌"

#: admin/views/tools-settings.php:116
msgid ""
"Removes temporary Turnstile/reCAPTCHA approvals. Example: use this after "
"changing bot protection keys or when users report repeated verification "
"prompts."
msgstr "移除临时 Turnstile/reCAPTCHA 通过记录。示例：更改机器人防护密钥后，或用户报告反复出现验证提示时使用。"

#: admin/views/tools-settings.php:119
msgid "Clear Linking Lockouts"
msgstr "清除链接锁定"

#: admin/views/tools-settings.php:120
